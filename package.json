{
  "name": "myapp",
  "version": "1.0.0",
  "scripts": {
    "reset": "npx rimraf node_modules ./**/node_modules",
    "setup": "pnpm i --frozen-lockfile",
    "dev": "modern dev",
    "build": "modern build",
    "analyze": "modern build --analyze",
    "start": "modern start",
    "serve": "modern serve",
    "new": "modern new",
    "lint": "biome check",
    "prepare": "simple-git-hooks",
    "upgrade": "modern upgrade",
    "webpack": "modern inspect"
  },
  "engines": {
    "node": ">=16.18.1"
  },
  "packageManager": "pnpm@10.0.0",
  "lint-staged": {
    "*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
      "biome check --files-ignore-unknown=true"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "dependencies": {
    "@modern-js/runtime": "2.64.1",
    "axios": "^1.7.9",
    "react": "~18.3.1",
    "react-dom": "~18.3.1",
    "slate": "^0.112.0",
    "slate-history": "^0.110.3",
    "slate-react": "^0.112.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@modern-js/app-tools": "2.64.1",
    "@modern-js/tsconfig": "2.64.1",
    "@types/react": "~18.3.18",
    "@types/react-dom": "~18.3.5",
    "lint-staged": "~15.4.3",
    "rimraf": "^6.0.1",
    "simple-git-hooks": "^2.11.1",
    "typescript": "~5.7.3"
  }
}
